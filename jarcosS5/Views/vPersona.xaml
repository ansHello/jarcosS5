<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="jarcosS5.Views.vPersona"
             Title="vPersona">
    <VerticalStackLayout
        Padding="15"
        Margin="20">
        <Label 
            Text="CRUD DE PERSONAS"
            FontSize="20"
            TextColor="red"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Entry x:Name="txtName"
               Placeholder="Ingresa el nombre"/>
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnAgregar"
                    Text="Agregar Persona"
                    Clicked="btnAgregar_Clicked"
                    Grid.Column="0"
                    Margin="0,0,4,0"/>
            <Button x:Name="btnActualizar"
                    Text="Actualizar Persona"
                    Clicked="btnActualizar_Clicked"
                    Grid.Column="1"
                    IsEnabled="False"
                    BackgroundColor="DarkOrange"
                    Margin="4,0,0,0"/>
        </Grid>

        <Button x:Name="btnCancelar"
                Text="Cancelar Edición"
                Clicked="btnCancelar_Clicked"
                IsVisible="False"
                BackgroundColor="Gray"
                Margin="0,6,0,0"/>
        
        <Label x:Name="lblStatus"
        TextColor="Blue"
        Grid.Row="1"
        Grid.Column="0"/>
        
        <Button x:Name="btnListar"
                Text="Listar Personas"
                Clicked="btnListar_Clicked"
                Margin="0,8,0,0"/>

        <CollectionView x:Name="listaPersonas"
                            Grid.Row="7"
                            Grid.Column="0"
                            Grid.ColumnSpan="2">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <Label Text="{Binding Id}"
                                   Grid.Row="0"
                                   Grid.Column="0"/>

                        <Label Text="{Binding Name}"
                                   Grid.Row="0"
                                   Grid.Column="1"/>

                        <Button x:Name="btnEditar"
                                Text="Editar"
                                BackgroundColor="DarkOrange"
                                TextColor="White"
                                FontSize="12"
                                Padding="4,2"
                                CommandParameter="{Binding .}"
                                Clicked="btnEditar_Clicked"
                                Grid.Row="0"
                                Grid.Column="2"/>
                        
                        <Button x:Name="btnEliminar"
                                Text="Eliminar"
                                BackgroundColor="DarkRed"
                                TextColor="White"
                                FontSize="12"
                                Padding="4,2"
                                CommandParameter="{Binding .}"
                                Clicked="btnEliminar_Clicked"
                                Grid.Row="0"
                                Grid.Column="3"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>